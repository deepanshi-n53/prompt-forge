# ── AI provider ───────────────────────────────────────────────────────────────
# Selects which model backend generates prompts (see lib/ai/ai-client.ts).
#   local dev  → AI_PROVIDER=ollama   (free, runs on your machine)
#   production → AI_PROVIDER=openai   (required; the app refuses to boot in
#                                      production with mock/ollama or unset)
AI_PROVIDER=ollama

# Only used when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
