datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Plan {
  FREE
  PROFESSIONAL
  AGENCY
  ENTERPRISE
}

enum ProjectStatus {
  DRAFT       // created, no BRD uploaded yet
  PARSING     // BRD uploaded, being parsed/analysed
  PROCESSING  // prompts actively generating
  PARSED      // parse done, awaiting setup answers
  READY       // generation complete
  ERROR
  UPDATING    // re-analysing after a BRD change
}

enum BRDStatus {
  PENDING
  PARSED
  FAILED
}

enum Track {
  FAST
  FULL
}

enum PromptStatus {
  GENERATED
  OUTDATED
  APPLIED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChangeEventStatus {
  PENDING
  APPLIED
  DISMISSED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id               String        @id @default(cuid())
  clerkId          String        @unique
  email            String        @unique
  name             String?
  avatarUrl        String?
  plan             Plan          @default(FREE)
  isNewUser        Boolean       @default(true)
  isInternalUser   Boolean       @default(false)
  stripeCustomerId String?       @unique
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  projects        Project[]
  memberships     OrgMember[]
  deletionRequest DeletionRequest?
  answerDefaults  UserAnswerDefault[]

  @@index([clerkId])
}

// Per-user remembered setup answers for cross-project pre-fill. Only "portable"
// preference fields are stored here (see lib/ai/answer-defaults.ts) — never an
// app's identity fields. One row per (user, field); the latest answer wins.
model UserAnswerDefault {
  id        String   @id @default(cuid())
  userId    String
  field     String
  value     String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, field])
  @@index([userId])
}

model Organisation {
  id               String    @id @default(cuid())
  clerkOrgId       String    @unique
  name             String
  plan             Plan      @default(FREE)
  stripeCustomerId String?
  stripeSubId      String?
  seats            Int       @default(1)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  members  OrgMember[]
  projects Project[]
}

model OrgMember {
  id       String   @id @default(cuid())
  orgId    String
  userId   String
  role     OrgRole  @default(MEMBER)
  joinedAt DateTime @default(now())

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(DRAFT)
  archetype           String?
  archetypeConfidence Float?
  track               Track         @default(FAST)
  aiCostCents      Int           @default(0) // accumulated AI spend across all runs, in cents
  aiGenerationRuns Int           @default(0) // number of completed generation runs
  ownerId     String
  orgId       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  owner        User           @relation(fields: [ownerId], references: [id])
  org          Organisation?  @relation(fields: [orgId], references: [id])
  brds         BRD[]
  decisions    DecisionGraph?
  prompts      GeneratedPrompt[]
  figmaLinks   FigmaLink[]
  changeEvents ChangeEvent[]

  @@index([ownerId])
  @@index([orgId])
}

model BRD {
  id           String   @id @default(cuid())
  projectId    String
  version      Int      @default(1)
  fileName     String
  storagePath  String
  fileSize     Int
  mimeType     String
  rawText      String?   @db.Text
  status       BRDStatus @default(PENDING)
  healthScore  Int?
  healthDetail Json?
  parsedContent Json?
  isActive     Boolean   @default(true)
  uploadedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, version])
}

model DecisionGraph {
  id        String   @id @default(cuid())
  projectId String   @unique
  decisions Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model GeneratedPrompt {
  id          String       @id @default(cuid())
  projectId   String
  sectionNum  String
  sectionName String
  layer       String
  track       Track
  content     String       @db.Text
  status      PromptStatus @default(GENERATED)
  confidence  Float?
  assumptions Json?
  brdVersion  Int          @default(1)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sectionNum, brdVersion])
  @@index([projectId])
}

model FigmaLink {
  id         String   @id @default(cuid())
  projectId  String
  figmaUrl   String
  parsedData Json?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ChangeEvent {
  id             String            @id @default(cuid())
  projectId      String
  oldBrdId       String
  newBrdId       String
  changeAnalysis Json
  status         ChangeEventStatus @default(PENDING)
  deltaPrompts   Json?
  appliedAt      DateTime?
  createdAt      DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model DeletionRequest {
  id           String    @id @default(cuid())
  userId       String    @unique
  requestedAt  DateTime  @default(now())
  scheduledFor DateTime
  completedAt  DateTime?

  user User @relation(fields: [userId], references: [id])
}
